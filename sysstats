}

function is_media() {
    local rec=0 stream=0 icon msg rec_mon stream_mon
    [[ -f "/tmp/recpid" ]] && rec=1
    [[ -f "/tmp/streampid" ]] && stream=1
    [[ -f "/tmp/recpid.monitor" ]] && rec_mon="$(cat /tmp/recpid.monitor)"
    [[ -f "/tmp/streampid.monitor" ]] && stream_mon="$(cat /tmp/streampid.monitor)"
    if [[ $rec -eq 1 && $stream -eq 1 ]]; then
        icon="¾░æŖ"
        msg="Rec (${rec_mon:-NA}) | Stream (${stream_mon:-NA})"
    elif [[ $rec -eq 1 ]]; then
        icon="¾░æŖ"
        msg="Recording (${rec_mon:-NA})"
    elif [[ $stream -eq 1 ]]; then
        icon="¾░æŖ"
        msg="Streaming (${stream_mon:-NA})"
    else
        icon="Ņ«¦"
        msg="Idle"
    fi
    echo "${icon} ${msg}"
}

function bbattery() {
    local battery_info valid_batteries active_battery_line percent status icon time_left
    if ! command -v acpi &> /dev/null; then
        echo "¾░éæ No acpi"; return
    fi
    battery_info=$(acpi -b 2>/dev/null || echo "")
    [[ -z "$battery_info" ]] && return
    valid_batteries=$(echo "$battery_info" | grep -v "Unknown" | grep -v "rate information unavailable" || true)
    active_battery_line=$([[ -n "$valid_batteries" ]] && echo "$valid_batteries" | head -n 1 || echo "$battery_info" | head -n 1)
    percent=$(echo "$active_battery_line" | grep -o '[0-9]\+%' | tr -d '%' | head -n 1 || echo "0")
    status=$(echo "$active_battery_line" | awk -F', ' '{print $1}' | awk -F': ' '{print $2}' || echo "Unknown")
    time_left=$(echo "$active_battery_line" | grep -oP '\d+:\d+:\d+' | head -n 1 || echo "")
    [[ -n "$time_left" ]] && time_left=$(echo "$time_left" | awk -F: '{printf "%d:%02d", $1, $2}')

    case "$status" in
        Charging|Not\ charging)
            if [[ $percent -ge 100 ]]; then icon="¾░éģ"
            elif [[ $percent -ge 90 ]]; then icon="¾░éŗ"
            elif [[ $percent -ge 80 ]]; then icon="¾░éŖ"
            elif [[ $percent -ge 70 ]]; then icon="¾░ó×"
            elif [[ $percent -ge 60 ]]; then icon="¾░éē"
            elif [[ $percent -ge 50 ]]; then icon="¾░óØ"
            elif [[ $percent -ge 40 ]]; then icon="¾░éł"
            elif [[ $percent -ge 30 ]]; then icon="¾░éć"
            elif [[ $percent -ge 20 ]]; then icon="¾░éå"
            elif [[ $percent -ge 10 ]]; then icon="¾░ó£"
        else icon="¾░ó¤"; fi ;;
        Discharging)
            if [[ $percent -ge 100 ]]; then icon="¾░ü╣"
            elif [[ $percent -ge 90 ]]; then icon="¾░éé"
            elif [[ $percent -ge 80 ]]; then icon="¾░éü"
            elif [[ $percent -ge 70 ]]; then icon="¾░éĆ"
            elif [[ $percent -ge 60 ]]; then icon="¾░ü┐"
            elif [[ $percent -ge 50 ]]; then icon="¾░üŠ"
            elif [[ $percent -ge 40 ]]; then icon="¾░üĮ"
            elif [[ $percent -ge 30 ]]; then icon="¾░ü╝"
            elif [[ $percent -ge 20 ]]; then icon="¾░ü╗"
            elif [[ $percent -ge 10 ]]; then icon="¾░ü║"
        else icon="¾░éÄ"; fi ;;
        Full) icon="¾░éä" ;;
        *) icon="¾░éæ" ;;
    esac
    [[ -n "$time_left" ]] && echo "${icon} ${percent}% (${time_left})" || echo "${icon} ${percent}%"
}

