    muted=$(pamixer --get-mute 2>/dev/null || echo "false")
    if [[ "$muted" == "true" || "$vol" -eq 0 ]]; then
        icon="¾░Ø¤"; msg="Muted"
    elif [[ "$vol" -eq 100 ]]; then icon="¾░Č¼"; msg="${vol}%"
    elif [[ "$vol" -ge 75 ]]; then icon="¾░ĢŠ"; msg="${vol}%"
    elif [[ "$vol" -ge 25 ]]; then icon="¾░¢Ć"; msg="${vol}%"
else icon="¾░Ģ┐"; msg="${vol}%"; fi
