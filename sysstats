function updates() {
    if command -v checkupdates &> /dev/null; then
        local count
        count=$(checkupdates 2>/dev/null | wc -l)
        [[ "$count" -gt 0 ]] && echo "¾░Ü░ ${count}"
    fi
}

function weather() {
    local weather_data icon code temp

    # 1. Fetch data. We use %k and %t separately to avoid splitting issues.
    # We use || true to ensure 'set -e' doesn't kill the script if the net is down.
    code=$(curl -4 -sL --max-time 3 "wttr.in?format=%k" 2>/dev/null || echo "")
    temp=$(curl -4 -sL --max-time 3 "wttr.in?format=%t" 2>/dev/null || echo "")

    # 2. If we have no temperature, exit silently
    [[ -z "$temp" ]] && return

    # 3. Clean the temperature string (remove + and spaces)
    temp=$(echo "$temp" | tr -d '+ ')

    # 4. Map codes to Nerd Font Icons
    case "$code" in
        113) icon="¾░¢Ö" ;; # Sunny
        116) icon="¾░¢Ģ" ;; # Partly Cloudy
        119|122) icon="¾░¢É" ;; # Cloudy
        143|248|260) icon="¾░¢æ" ;; # Fog
        176|263|266|293|296|299|302|305|308) icon="¾░¢Ś" ;; # Rain
        200|386|389|392|395) icon="¾░ÖŠ" ;; # Storm
        179|182|185|227|230|323|326|329|332|335|338) icon="¾░╝Č" ;; # Snow
        *) icon="¾░¢É" ;; # Default Cloud
    esac

    echo "${icon} ${temp}"
}

function network_ips() {
    local priv_ip pub_ip
    priv_ip=$(ip route get 1.1.1.1 2>/dev/null | awk '{print $7}' | head -n1 || echo "N/A")
    pub_ip=$(curl -4 -s --max-time 2 ifconfig.me 2>/dev/null || echo "Offline")
    echo "¾░®¤ ${priv_ip} | ¾░®Ā ${pub_ip}"
}

function all_stats() {
    local u=$(updates)
    local w=$(weather)
    [[ -n "$u" ]] && echo -n "$u | "
    [[ -n "$w" ]] && echo -n "$w | "
    echo "$(is_media) | $(cpu_load) | $(ggpu) | $(memory_usage) | $(disk_usage) | $(vvolume) | $(bbattery) | $(network_ips) | $(wifi_status) | $(date_time)"
}

