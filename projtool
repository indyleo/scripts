#!/usr/bin/env bash
# projtool - unified project management helper with Arduino CLI support
set -euo pipefail

# Self-integrity check: verify this script file still contains real tab
# characters where needed. Editors and copy-paste can silently convert
# tabs to spaces, which breaks generated Makefiles.
# The marker below MUST start with a real tab character:
#	PROJTOOL_TAB_MARKER
if ! grep -qP '^\t' "$0" 2>/dev/null && ! grep -q $'^\t' "$0" 2>/dev/null; then
    printf '\033[1;33m⚠️  WARNING: projtool may have been corrupted (tabs converted to spaces).\n'
    printf '   Generated Makefiles will fail with "missing separator".\n'
    printf '   Re-download the script and install with: install -m755 projtool ~/.local/bin/projtool\033[0m\n'
fi

PROJECTS_DIR="${PROJECTS_DIR:-$HOME/Projects}"
mkdir -pv "$PROJECTS_DIR"

# Colors
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
RED="\033[0;31m"
RESET="\033[0m"

declare -A TEMPLATES=(
    [sh]="#!/usr/bin/env bash
set -euo pipefail
echo 'Hello from Bash'"
    [py]="#!/usr/bin/env python3
def main():
    print('Hello from Python')
if __name__ == '__main__':
    main()"
    [lua]=""   # handled separately
    [nvim]=""  # neovim plugin scaffold, handled separately
    [c]="#include <stdio.h>
int main() { printf(\"Hello from C\\n\"); return 0; }"
    [cpp]="#include <iostream>
int main() { std::cout << \"Hello from C++\" << std::endl; return 0; }"
    [rs]=""    # rust handled by cargo
    [go]="package main
import \"fmt\"
func main() { fmt.Println(\"Hello from Go\") }"
    [zig]=""   # zig init will supply defaults
    [ino]=""   # arduino-cli handled separately
)

# Default build system per language (make | just | sh | "")
declare -A DEFAULT_BUILD=(
    [sh]="sh"
    [py]="sh"
    [lua]="sh"
    [nvim]=""      # no build system for nvim plugins
    [c]="make"
    [cpp]="make"
    [go]="make"
    [rs]=""        # cargo handles everything
    [zig]=""       # zig build handles everything
    [ino]="make"
)

function print_color() { printf "${1}%s${RESET}\n" "${2}"; }

# -----------------------------
# mkproj
# -----------------------------
function mkproj() {
    local auto_yes=false
    local project_name=""
    local language=""
    local arduino_board=""
    local build_system=""   # make | just | sh | "" (auto/default)

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n|--name)    project_name="${2-}";  shift 2 ;;
            -l|--lang)    language="${2-}";      shift 2 ;;
            -b|--board)   arduino_board="${2-}"; shift 2 ;;
            -B|--build)   build_system="${2-}";  shift 2 ;;
            -y|--yes)     auto_yes=true;         shift ;;
            *) shift ;;
        esac
    done

    [[ -z "$project_name" ]] && read -rp "Project Name: " project_name
    [[ -z "$project_name" ]] && print_color "$RED" "❌ No name given." && return 1
    [[ "$project_name" =~ [^a-zA-Z0-9_-] ]] && print_color "$RED" "❌ Invalid project name (use a-z, A-Z, 0-9, _ -)." && return 1

    if [[ -z "$language" ]]; then
        local langs
        langs=$(IFS=,; echo "${!TEMPLATES[*]}")
        read -rp "Language ($langs): " language
    fi

    # Normalize aliases
    language=$(echo "$language" | tr '[:upper:]' '[:lower:]')
    case "$language" in
        c++)         language="cpp"  ;;
        bash)        language="sh"   ;;
        python)      language="py"   ;;
        rust)        language="rs"   ;;
        neovim|vim)  language="nvim" ;;
    esac

    if [[ -z "${TEMPLATES[$language]+x}" ]]; then
        print_color "$YELLOW" "⚠️  Unknown language '$language'. Creating basic scaffolding."
    fi

    # Resolve build system: flag > prompt > default
    if [[ -z "$build_system" ]]; then
        local default_bs="${DEFAULT_BUILD[$language]:-}"
        if [[ -n "$default_bs" ]]; then
            if $auto_yes; then
                build_system="$default_bs"
            else
                read -rp "Build system for $language [make/just/sh] (default: $default_bs): " build_system
                [[ -z "$build_system" ]] && build_system="$default_bs"
            fi
        fi
    fi

    build_system=$(echo "$build_system" | tr '[:upper:]' '[:lower:]')

    case "$build_system" in
        make|just|sh|"") ;;
        *) print_color "$RED" "❌ Unknown build system '$build_system'. Choose: make, just, sh"; return 1 ;;
    esac

    local proj_path="$PROJECTS_DIR/$project_name"

    case "$language" in
        py|sh|lua)  mkdir -pv "$proj_path/src" ;;
        nvim)       mkdir -pv "$proj_path/lua/$project_name/functions" "$proj_path/plugin" ;;
        rs)         mkdir -pv "$proj_path" ;;
        c|cpp|go)   mkdir -pv "$proj_path/src" "$proj_path/include" "$proj_path/bin" ;;
        zig)        mkdir -pv "$proj_path/src" "$proj_path/include" ;;
        ino)        mkdir -pv "$proj_path/sketch" ;;
        *)          mkdir -pv "$proj_path/src" ;;
    esac

    cd "$proj_path" || return

    case "$language" in
        sh)
            echo "${TEMPLATES[sh]}" > "src/main.sh"
            chmod +x "src/main.sh"
            print_color "$GREEN" "✅ Created src/main.sh"
            _write_build_sh_bash "$project_name" "$build_system"
            ;;

        py)
            echo "${TEMPLATES[py]}" > "src/main.py"
            chmod +x "src/main.py"
            if command -v python3 >/dev/null 2>&1; then
                python3 -m venv "venv" 2>/dev/null || true
                print_color "$GREEN" "✅ Python venv created at venv/"
            fi
            _write_build_py "$project_name" "$build_system"
            ;;

        lua)
            cat > "src/main.lua" <<'EOF'
-- main.lua
local function main()
    print("Hello from Lua")
end

main()
EOF
            print_color "$GREEN" "✅ Created src/main.lua"
            _write_build_lua "$project_name" "$build_system"
            ;;

        nvim)
            cat > "lua/$project_name/init.lua" <<EOF
local M = {}

--- Plugin setup. Pass a table of options to configure behaviour.
---@param opts table|nil
function M.setup(opts)
    opts = opts or {}
    -- TODO: initialise your plugin here
    vim.notify("${project_name} loaded", vim.log.levels.INFO)
end

return M
EOF
            # Minimal plugin loader shim
            cat > "plugin/${project_name}.lua" <<EOF
-- Entry point loaded automatically by Neovim's plugin runtime.
-- Users call require("${project_name}").setup({}) from their config.
EOF
            print_color "$GREEN" "✅ Created Neovim plugin scaffold"
            print_color "$YELLOW" "💡 Users load this plugin with: require(\"${project_name}\").setup({})"
            ;;

        rs)
            if command -v cargo >/dev/null 2>&1; then
                (cargo init --name "$project_name" . 2>&1) | sed 's/^/cargo: /' >&2 || true
                print_color "$GREEN" "Initialized Rust project with cargo"
                cargo build --release >/dev/null 2>&1 && print_color "$GREEN" "✅ Rust compiled"
            else
                print_color "$RED" "cargo not found"
            fi
            ;;

        zig)
            print_color "$GREEN" "Preparing Zig project; using 'zig init' defaults"
            if command -v zig >/dev/null 2>&1; then
                [[ ! -f build.zig ]] && zig init 2> >(sed 's/^/zig: /' >&2)
                print_color "$GREEN" "✅ zig init completed"

                local built=false
                local used_mode="debug"
                if zig build 2> >(sed 's/^/zig: /' >&2); then
                    built=true
                else
                    for mode in fast safe small; do
                        if zig build --release="$mode" 2> >(sed 's/^/zig: /' >&2); then
                            built=true
                            used_mode="$mode"
                            break
                        fi
                    done
                fi

                if $built; then
                    local exe_path
                    exe_path=$(find zig-out -type f -executable -print 2>/dev/null | head -n1 || true)
                    if [[ -n "$exe_path" ]]; then
                        print_color "$GREEN" "✅ Zig build succeeded (mode: $used_mode). Executable: $exe_path"
                    else
                        print_color "$YELLOW" "zig build ran but no executable detected."
                    fi
                else
                    print_color "$RED" "❌ All zig build attempts failed."
                fi
            else
                print_color "$RED" "zig not found"
            fi
            ;;

        c)
            echo "${TEMPLATES[c]}" > "src/main.c"
            _write_build_c "$project_name" "c" "$build_system"
            _try_build "$build_system" "$project_name"
            ;;

        cpp)
            echo "${TEMPLATES[cpp]}" > "src/main.cpp"
            _write_build_c "$project_name" "cpp" "$build_system"
            _try_build "$build_system" "$project_name"
            ;;

        go)
            echo "${TEMPLATES[go]}" > "src/main.go"
            _write_build_go "$project_name" "$build_system"
            _try_build "$build_system" "$project_name"
            ;;

        ino)
            if ! command -v arduino-cli >/dev/null 2>&1; then
                print_color "$RED" "❌ arduino-cli not found in PATH"
                return 1
            fi

            print_color "$GREEN" "Initializing Arduino CLI configuration..."
            arduino-cli config init --overwrite 2>&1 | sed 's/^/arduino-cli: /' >&2 || true
            arduino-cli core update-index          2>&1 | sed 's/^/arduino-cli: /' >&2 || true

            if [[ -z "$arduino_board" ]]; then
                if $auto_yes; then
                    arduino_board="arduino:avr:uno"
                else
                    read -rp "Board FQBN (default: arduino:avr:uno): " arduino_board
                    [[ -z "$arduino_board" ]] && arduino_board="arduino:avr:uno"
                fi
            fi

            if [[ ! "$arduino_board" =~ ^[a-zA-Z0-9_-]+:[a-zA-Z0-9_-]+:[a-zA-Z0-9_-]+$ ]]; then
                print_color "$RED" "❌ Invalid FQBN '$arduino_board'. Expected: vendor:arch:board (e.g. arduino:avr:uno)"
                return 1
            fi

            local vendor arch
            IFS=: read -r vendor arch _ <<< "$arduino_board"

            print_color "$GREEN" "Installing core for board: $arduino_board"
            arduino-cli core install "$vendor:$arch" 2>&1 | sed 's/^/arduino-cli: /' >&2 || true

            cat > "sketch/${project_name}.ino" <<EOF
void setup() {
  Serial.begin(9600);
  pinMode(LED_BUILTIN, OUTPUT);
}

void loop() {
  digitalWrite(LED_BUILTIN, HIGH);
  delay(1000);
  digitalWrite(LED_BUILTIN, LOW);
  delay(1000);
}
EOF
            # Arduino always uses Makefile
            cat > Makefile <<EOF
BOARD  = ${arduino_board}
PORT  ?= /dev/ttyACM0

.PHONY: compile upload monitor clean

compile:
	arduino-cli compile --fqbn \$(BOARD) sketch

upload:
	arduino-cli upload -p \$(PORT) --fqbn \$(BOARD) sketch

monitor:
	arduino-cli monitor -p \$(PORT)

clean:
	rm -rf sketch/build
EOF
            print_color "$GREEN" "✅ Arduino project created with board: $arduino_board"
            print_color "$YELLOW" "💡 Use 'make compile', 'make upload', or 'make monitor'"
            ;;

        *)
            print_color "$YELLOW" "⚠️  Unknown language: created basic src/"
            ;;
    esac

    _setup_gitignore "$language"
    print_color "$GREEN" "✅ Project created at $proj_path"
    _check_and_offer_setup "$language" "$auto_yes" "$build_system"
}

# -----------------------------
# Build system writers
# -----------------------------

# Write a Makefile from a heredoc, converting the two-character sequence
# \t at the start of a line into a real tab character.
# This is necessary because:
#   - printf '\t' behaviour varies between /bin/sh implementations
#   - editors silently convert literal tabs in heredocs to spaces
# Using sed with a bash $'\t' variable is portable and editor-safe.
function _write_makefile() {
    local TAB
    TAB=$'\t'
    sed "s/^\\\\t/$TAB/;s/\\\\t/$TAB/g"
}

# Try to run the initial build after scaffolding (compiled langs only)
function _try_build() {
    local bs="$1" name="$2"
    case "$bs" in
        make) command -v make >/dev/null 2>&1 && make --no-print-directory build 2>/dev/null \
                && print_color "$GREEN" "✅ Built bin/$name" || true ;;
        just) command -v just >/dev/null 2>&1 && just build 2>/dev/null \
                && print_color "$GREEN" "✅ Built bin/$name" || true ;;
        sh)   [[ -x build.sh ]] && ./build.sh build 2>/dev/null \
                && print_color "$GREEN" "✅ Built bin/$name" || true ;;
    esac
}

# C / C++ — supports make, just, or sh
function _write_build_c() {
    local name="$1" lang="$2" bs="$3"
    local cc ext
    if [[ "$lang" == "cpp" ]]; then cc="g++"; ext="cpp"; else cc="gcc"; ext="c"; fi

    case "$bs" in
        make)
            _write_makefile > Makefile <<EOF
CC      = ${cc}
CFLAGS  = -Wall -Wextra -g
TARGET  = bin/${name}
SRC     = \$(wildcard src/*.${ext})

.DEFAULT_GOAL := build
.PHONY: build run clean

build: \$(SRC)
\t\$(CC) \$(CFLAGS) -Iinclude -o \$(TARGET) \$^

run: build
\t./\$(TARGET)

clean:
\trm -f \$(TARGET)
EOF
            print_color "$GREEN" "✅ Makefile created" ;;

        just)
            cat > justfile <<EOF
cc     := "${cc}"
cflags := "-Wall -Wextra -g"
target := "bin/${name}"

# Default: build
default: build

# Compile
build:
    {{cc}} {{cflags}} -Iinclude -o {{target}} src/*.${ext}

# Build and run
run: build
    ./{{target}}

# Remove compiled output
clean:
    rm -f {{target}}
EOF
            print_color "$GREEN" "✅ justfile created" ;;

        sh)
            cat > build.sh <<EOF
#!/usr/bin/env bash
set -euo pipefail

CC="${cc}"
CFLAGS="-Wall -Wextra -g"
TARGET="bin/${name}"
SRC=(\$(ls src/*.${ext} 2>/dev/null))

case "\${1:-build}" in
    build)
        \$CC \$CFLAGS -Iinclude -o "\$TARGET" "\${SRC[@]}"
        echo "✅ Built \$TARGET"
        ;;
    run)
        \$0 build
        ./"\$TARGET" "\${@:2}"
        ;;
    clean)
        rm -f "\$TARGET"
        echo "✅ Cleaned"
        ;;
    *)
        echo "Usage: \$0 {build|run|clean}"
        exit 1
        ;;
esac
EOF
            chmod +x build.sh
            print_color "$GREEN" "✅ build.sh created" ;;
    esac
}

# Go — supports make, just, or sh
function _write_build_go() {
    local name="$1" bs="$2"

    case "$bs" in
        make)
            _write_makefile > Makefile <<EOF
TARGET  = bin/${name}
SRC     = \$(wildcard src/*.go)

.DEFAULT_GOAL := build
.PHONY: build run clean

build: \$(SRC)
\tgo build -o \$(TARGET) \$^

run: build
\t./\$(TARGET)

clean:
\trm -f \$(TARGET)
EOF
            print_color "$GREEN" "✅ Makefile created" ;;

        just)
            cat > justfile <<EOF
target := "bin/${name}"

# Default: build
default: build

# Compile
build:
    go build -o {{target}} src/*.go

# Build and run
run: build
    ./{{target}}

# Remove compiled output
clean:
    rm -f {{target}}
EOF
            print_color "$GREEN" "✅ justfile created" ;;

        sh)
            cat > build.sh <<EOF
#!/usr/bin/env bash
set -euo pipefail

TARGET="bin/${name}"
SRC=(\$(ls src/*.go 2>/dev/null))

case "\${1:-build}" in
    build)
        go build -o "\$TARGET" "\${SRC[@]}"
        echo "✅ Built \$TARGET"
        ;;
    run)
        \$0 build
        ./"\$TARGET" "\${@:2}"
        ;;
    clean)
        rm -f "\$TARGET"
        echo "✅ Cleaned"
        ;;
    *)
        echo "Usage: \$0 {build|run|clean}"
        exit 1
        ;;
esac
EOF
            chmod +x build.sh
            print_color "$GREEN" "✅ build.sh created" ;;
    esac
}

# Python — build.sh is idiomatic default; make and just wrappers also available
function _write_build_py() {
    local name="$1" bs="$2"

    case "$bs" in
        sh)
            cat > build.sh <<EOF
#!/usr/bin/env bash
# build.sh — helper for ${name}
set -euo pipefail

VENV="venv"
SRC="src/main.py"

case "\${1:-run}" in
    setup)
        python3 -m venv "\$VENV"
        # shellcheck disable=SC1091
        source "\$VENV/bin/activate"
        [[ -f requirements.txt ]] && pip install -r requirements.txt
        echo "✅ venv ready"
        ;;
    run)
        # shellcheck disable=SC1091
        source "\$VENV/bin/activate" 2>/dev/null || true
        python3 "\$SRC" "\${@:2}"
        ;;
    lint)
        command -v flake8 >/dev/null 2>&1 && flake8 "\$SRC" || echo "flake8 not found"
        ;;
    clean)
        find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
        echo "✅ Cleaned"
        ;;
    *)
        echo "Usage: \$0 {setup|run|lint|clean}"
        exit 1
        ;;
esac
EOF
            chmod +x build.sh
            print_color "$GREEN" "✅ build.sh created" ;;

        make)
            _write_makefile > Makefile <<'EOF'
VENV = venv
SRC  = src/main.py

.DEFAULT_GOAL := run
.PHONY: run setup lint clean

run:
\t. $(VENV)/bin/activate 2>/dev/null || true; python3 $(SRC)

setup:
\tpython3 -m venv $(VENV)
\t. $(VENV)/bin/activate && pip install -r requirements.txt 2>/dev/null || true

lint:
\t. $(VENV)/bin/activate 2>/dev/null || true; flake8 $(SRC) 2>/dev/null || echo "flake8 not found"

clean:
\tfind . -type d -name __pycache__ -exec rm -rf {} +
EOF
            print_color "$GREEN" "✅ Makefile created" ;;

        just)
            cat > justfile <<'JEOF'
venv := "venv"
src  := "src/main.py"

# Default: run
default: run

# Create venv and install deps
setup:
    python3 -m venv {{venv}}
    . {{venv}}/bin/activate && pip install -r requirements.txt 2>/dev/null || true

# Run main script
run:
    . {{venv}}/bin/activate 2>/dev/null || true; python3 {{src}}

# Lint with flake8
lint:
    . {{venv}}/bin/activate 2>/dev/null || true; flake8 {{src}} 2>/dev/null || echo "flake8 not found"

# Clean pycache
clean:
    find . -type d -name __pycache__ -exec rm -rf {} +
JEOF
            print_color "$GREEN" "✅ justfile created" ;;
    esac
}

# Lua (plain program) — build.sh, make, or just
function _write_build_lua() {
    local name="$1" bs="$2"

    case "$bs" in
        sh)
            cat > build.sh <<EOF
#!/usr/bin/env bash
# build.sh — helper for ${name}
set -euo pipefail

SRC="src/main.lua"

case "\${1:-run}" in
    run)
        command -v lua >/dev/null 2>&1 || { echo "lua not found"; exit 1; }
        lua "\$SRC" "\${@:2}"
        ;;
    check)
        command -v luacheck >/dev/null 2>&1 && luacheck "\$SRC" || echo "luacheck not found"
        ;;
    clean)
        find . -name "*.luac" -delete
        echo "✅ Cleaned"
        ;;
    *)
        echo "Usage: \$0 {run|check|clean}"
        exit 1
        ;;
esac
EOF
            chmod +x build.sh
            print_color "$GREEN" "✅ build.sh created" ;;

        make)
            _write_makefile > Makefile <<'EOF'
SRC = src/main.lua

.DEFAULT_GOAL := run
.PHONY: run check clean

run:
\tlua $(SRC)

check:
\tluacheck $(SRC) 2>/dev/null || echo "luacheck not found"

clean:
\tfind . -name "*.luac" -delete
EOF
            print_color "$GREEN" "✅ Makefile created" ;;

        just)
            cat > justfile <<EOF
src := "src/main.lua"

# Default: run
default: run

# Run the script
run:
    lua {{src}}

# Lint with luacheck
check:
    luacheck {{src}} 2>/dev/null || echo "luacheck not found"

# Clean compiled bytecode
clean:
    find . -name "*.luac" -delete
EOF
            print_color "$GREEN" "✅ justfile created" ;;
    esac
}

# Bash — build.sh, make, or just
function _write_build_sh_bash() {
    local name="$1" bs="$2"

    case "$bs" in
        sh)
            cat > build.sh <<EOF
#!/usr/bin/env bash
# build.sh — helper for ${name}
set -euo pipefail

SRC="src/main.sh"

case "\${1:-run}" in
    run)
        bash "\$SRC" "\${@:2}"
        ;;
    lint)
        command -v shellcheck >/dev/null 2>&1 && shellcheck "\$SRC" || echo "shellcheck not found"
        ;;
    clean)
        echo "Nothing to clean"
        ;;
    *)
        echo "Usage: \$0 {run|lint|clean}"
        exit 1
        ;;
esac
EOF
            chmod +x build.sh
            print_color "$GREEN" "✅ build.sh created" ;;

        make)
            _write_makefile > Makefile <<'EOF'
SRC = src/main.sh

.DEFAULT_GOAL := run
.PHONY: run lint clean

run:
\tbash $(SRC)

lint:
\tshellcheck $(SRC) 2>/dev/null || echo "shellcheck not found"

clean:
\t@echo "Nothing to clean"
EOF
            print_color "$GREEN" "✅ Makefile created" ;;

        just)
            cat > justfile <<EOF
src := "src/main.sh"

# Default: run
default: run

# Run the script
run:
    bash {{src}}

# Lint with shellcheck
lint:
    shellcheck {{src}} 2>/dev/null || echo "shellcheck not found"

# Nothing to clean for shell scripts
clean:
    echo "Nothing to clean"
EOF
            print_color "$GREEN" "✅ justfile created" ;;
    esac
}

# -----------------------------
# mkgit
# -----------------------------
function mkgit() {
    [[ -d .git ]] && { print_color "$YELLOW" "⚙️ Git repo exists."; return; }
    git init
    git add .
    git commit -m "Initial commit"
    print_color "$GREEN" "✅ Git initialized."
}

# -----------------------------
# .gitignore creation
# -----------------------------
function _setup_gitignore() {
    local lang="${1:-}"
    case "$lang" in
        sh)
            cat > .gitignore <<'EOF'
# Shell
*.swp
EOF
            ;;
        py)
            cat > .gitignore <<'EOF'
# Python
__pycache__/
*.py[cod]
*.swp
venv/
.env
EOF
            ;;
        lua|nvim)
            cat > .gitignore <<'EOF'
# Lua
*.luac
*.swp
EOF
            ;;
        c|cpp)
            cat > .gitignore <<'EOF'
# C/C++
*.o
*.exe
bin/
*.swp
EOF
            ;;
        go)
            cat > .gitignore <<'EOF'
# Go
bin/
*.exe
*.swp
EOF
            ;;
        rs)
            cat > .gitignore <<'EOF'
# Rust
target/
*.swp
EOF
            ;;
        zig)
            cat > .gitignore <<'EOF'
# Zig
zig-out/
zig-cache/
*.swp
EOF
            ;;
        ino)
            cat > .gitignore <<'EOF'
# Arduino
sketch/build/
*.swp
EOF
            ;;
        *)
            cat > .gitignore <<'EOF'
# General
*.swp
EOF
            ;;
    esac

    print_color "$GREEN" "✅ .gitignore created for $lang"
}

# -----------------------------
# README usage block generator
# -----------------------------
function _readme_usage_block() {
    local lang="$1" bs="$2" name="$3"

    case "$lang" in
        sh)
            case "$bs" in
                make) echo "make run
make lint    # shellcheck
make clean" ;;
                just) echo "just run
just lint    # shellcheck
just clean" ;;
                sh|*) echo "./build.sh run
./build.sh lint    # shellcheck
./build.sh clean" ;;
            esac ;;

        py)
            case "$bs" in
                make) echo "make setup   # create venv + install deps
make run
make lint    # flake8
make clean" ;;
                just) echo "just setup   # create venv + install deps
just run
just lint    # flake8
just clean" ;;
                sh|*) echo "./build.sh setup   # create venv + install deps
./build.sh run
./build.sh lint   # flake8
./build.sh clean" ;;
            esac ;;

        lua)
            case "$bs" in
                make) echo "make run
make check   # luacheck
make clean" ;;
                just) echo "just run
just check   # luacheck
just clean" ;;
                sh|*) echo "./build.sh run
./build.sh check   # luacheck
./build.sh clean" ;;
            esac ;;

        nvim) echo '-- In your Neovim config (init.lua):
require("'"$name"'").setup({})' ;;

        c|cpp)
            case "$bs" in
                just) echo "just build
just run
just clean" ;;
                sh)   echo "./build.sh build
./build.sh run
./build.sh clean" ;;
                make|*) echo "make        # build
make run
make clean" ;;
            esac ;;

        go)
            case "$bs" in
                just) echo "just build
just run
just clean" ;;
                sh)   echo "./build.sh build
./build.sh run
./build.sh clean" ;;
                make|*) echo "make        # build
make run
make clean" ;;
            esac ;;

        rs) echo "cargo build --release
cargo run
cargo test" ;;

        zig) echo "zig build
zig build run
zig build test" ;;

        ino) echo "make compile            # compile sketch
make upload PORT=/dev/ttyACM0
make monitor PORT=/dev/ttyACM0
make clean" ;;

        *) echo "# Run or build instructions go here" ;;
    esac
}

# -----------------------------
# Docs setup
# -----------------------------
function setupdocs() {
    local language="${1:-}"
    local build_system="${2:-}"
    local name year author
    name="$(basename "$PWD")"
    year="$(date +%Y)"
    author="$(git config user.name 2>/dev/null || whoami 2>/dev/null || echo 'Unknown Author')"

    # Build the Usage snippet based on language + build system
    local usage_block
    usage_block="$(_readme_usage_block "$language" "$build_system" "$name")"

    cat > README.md <<EOF
# $name

## Usage
\`\`\`bash
${usage_block}
\`\`\`

## License
MIT
EOF

    cat > LICENSE <<EOF
MIT License

Copyright (c) $year $author

Permission is hereby granted, free of charge, to any person obtaining a copy
of this software and associated documentation files (the "Software"), to deal
in the Software without restriction, including without limitation the rights
to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
copies of the Software, and to permit persons to whom the Software is
furnished to do so, subject to the following conditions:

The above copyright notice and this permission notice shall be included in all
copies or substantial portions of the Software.

THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
SOFTWARE.
EOF
    print_color "$GREEN" "✅ README.md and LICENSE created"
}

# -----------------------------
# Offer setup for docs/git
# -----------------------------
function _check_and_offer_setup() {
    local language="$1"
    local auto_yes="$2"
    local build_system="${3:-}"
    local ans

    if $auto_yes; then
        setupdocs "$language" "$build_system"
        # cargo init already sets up git; skip for rs
        [[ "$language" != "rs" && ! -d .git ]] && mkgit
    else
        if [[ ! -f README.md || ! -f LICENSE ]]; then
            read -rp "❔ Set up docs now? (y/N): " ans
            [[ "$ans" =~ ^[Yy]$ ]] && setupdocs "$language" "$build_system"
        fi
        if [[ "$language" != "rs" && ! -d .git ]]; then
            read -rp "❔ Initialize Git? (y/N): " ans
            [[ "$ans" =~ ^[Yy]$ ]] && mkgit
        fi
    fi
}

# -----------------------------
# Usage/help
# -----------------------------
function usage() {
    cat <<'EOF'
Usage: projtool <command> [options]

Commands:
  mkproj       Create a new project
               Options:
                 -n <name>          Project name
                 -l <lang>          Language (see below)
                 -B <build-system>  Build system: make | just | sh  (overrides default)
                 -b <fqbn>          Arduino board FQBN (e.g. arduino:avr:uno)
                 -y                 Skip prompts; auto-create docs and git
  mkgit        Initialize Git in current directory
  setupdocs    Create README.md and LICENSE

Languages & default build systems:
  sh    Bash script              build.sh (default) | make | just
  py    Python                   build.sh (default) | make | just
  lua   Plain Lua program        build.sh (default) | make | just
  nvim  Neovim plugin scaffold   (no build system)
  c     C                        Makefile (default) | just | sh
  cpp   C++                      Makefile (default) | just | sh
  go    Go                       Makefile (default) | just | sh
  rs    Rust (via cargo)         (cargo handles everything)
  zig   Zig (via zig build)      (zig build handles everything)
  ino   Arduino sketch           Makefile (arduino-cli)

Build system targets:
  make / Makefile   all|compile / run / clean  (+ upload/monitor for ino)
  just / justfile   build / run / clean
  sh   / build.sh   build|run / run / lint|check / clean

Examples:
  projtool mkproj -n hello -l c
  projtool mkproj -n hello -l c    -B just
  projtool mkproj -n hello -l c    -B sh
  projtool mkproj -n script -l sh  -B make
  projtool mkproj -n plugin -l nvim
  projtool mkproj -n script -l lua
  projtool mkproj -n webapp -l py  -y
  projtool mkproj -n blink  -l ino -b esp32:esp32:esp32
EOF
}

# -----------------------------
# Main dispatcher
# -----------------------------
case "${1:-}" in
    mkproj)    shift; mkproj "$@" ;;
    mkgit)     mkgit ;;
    setupdocs) shift; setupdocs "${1:-}" "${2:-}" ;;
    *)         usage ;;
esac

