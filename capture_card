#!/bin/env bash

# --- Detection ---
VIDEO_DEV=$(v4l2-ctl --list-devices 2>/dev/null | awk '/usb|UVC|HDMI|Capture/{getline; print $1; exit}')
AUDIO_SRC="alsa_input.usb-MACROSILICON_USB3.0_Capture_20210621-02.analog-stereo"

echo "🏎️  1280x720 @ 60 FPS Mode"
echo "🔊 Activating Audio Loopback..."

# Start the PipeWire loopback in the background
# This forces the capture card audio to your speakers
LOOPBACK_ID=$(pactl load-module module-loopback source="$AUDIO_SRC" sink="@DEFAULT_SINK@" latency_msec=1)

# Function to clean up the loopback when you quit
cleanup() {
    echo "🛑 Cleaning up audio loopback..."
    pactl unload-module "$LOOPBACK_ID"
    exit
}
trap cleanup SIGINT SIGTERM

# Launch MPV for Video (we don't need --audio-file now because Loopback handles it)
mpv av://v4l2:"$VIDEO_DEV" \
    --no-audio \
    --profile=low-latency \
    --untimed \
    --cache=no \
    --demuxer-lavf-o=video_size=1280x720,framerate=60,input_format=mjpeg,fflags=nobuffer \
    --title="720p 60FPS Low Latency"

# When MPV closes, trigger cleanup
cleanup
