#!/usr/bin/env python3
"""
Emoji Picker (Wayland version)
Downloads emoji data and provides a fuzzy finder interface for selection
"""

import argparse
import os
import re
import subprocess
import sys
from pathlib import Path

import requests

# --- Display server detection ---
IS_WAYLAND = bool(os.environ.get("WAYLAND_DISPLAY"))

# Configuration
CACHE_DIR = Path.home() / ".cache" / "emoji-picker"
EMOJI_FILE = CACHE_DIR / "emoji.txt"
EMOJI_URL = "https://unicode.org/Public/emoji/latest/emoji-test.txt"


def ensure_cache_dir():
    """Create cache directory if it doesn't exist"""
    CACHE_DIR.mkdir(parents=True, exist_ok=True)


def download_emoji_data():
    """Download and parse emoji list from Unicode.org emoji-test.txt"""
    print("Downloading emoji data...", file=sys.stderr)

    try:
        response = requests.get(EMOJI_URL, timeout=30)
        response.raise_for_status()

        emojis = []
        # Format: 1F600 ; fully-qualified # 😀 E1.0 grinning face
        pattern = re.compile(
            r"^[0-9A-F ]+;\s*fully-qualified\s*#\s*(\S+)\s+E\d+\.\d+\s+(.+)$"
        )

        for line in response.text.splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            match = pattern.match(line)
            if match:
                glyph = match.group(1)
                name = match.group(2).strip()
                emojis.append(f"{glyph} {name}")

        if emojis:
            ensure_cache_dir()
            with open(EMOJI_FILE, "w", encoding="utf-8") as f:
                f.write("\n".join(emojis))
            print(f"Downloaded {len(emojis)} emojis to {EMOJI_FILE}", file=sys.stderr)
            return True

        print("No emojis found in source file", file=sys.stderr)
        return False

    except requests.RequestException as e:
        print(f"Error downloading: {e}", file=sys.stderr)
        return False
    except IOError as e:
        print(f"Error writing cache file: {e}", file=sys.stderr)
        return False


def check_dependencies():
    """Check if required tools are available"""
    if IS_WAYLAND:
        finders = ["wofi", "fuzzel", "tofi", "rofi"]
        clip_tools = [("wl-copy", None)]
        clip_err = "wl-copy not found. Please install wl-clipboard."
    else:
        finders = ["dmenu", "rofi"]
        clip_tools = [("xsel", None), ("xclip", None)]
        clip_err = "Neither xsel nor xclip found. Please install one."

    selected_finder = None
    for finder in finders:
        if (
            subprocess.run(
                ["which", finder], capture_output=True, check=False
            ).returncode
            == 0
        ):
            selected_finder = finder
            break

    if not selected_finder:
        print(f"Error: No menu tool found. Tried: {finders}", file=sys.stderr)
        sys.exit(1)

    has_clip = any(
        subprocess.run(["which", tool], capture_output=True, check=False).returncode
        == 0
        for tool, _ in clip_tools
    )
    if not has_clip:
        print(f"Error: {clip_err}", file=sys.stderr)
        sys.exit(1)

    return selected_finder


def show_selection_menu(finder):
    """Display selection menu using available fuzzy finder"""
    if not EMOJI_FILE.exists():
        print("Cache file not found. Downloading...", file=sys.stderr)
        if not download_emoji_data():
            sys.exit(1)

    with open(EMOJI_FILE, "r", encoding="utf-8") as f:
        emoji_data = f.read()

    if finder == "wofi":
        cmd = ["wofi", "--dmenu", "--lines", "10", "--prompt", "Select Emoji:"]
    elif finder == "fuzzel":
        cmd = ["fuzzel", "--dmenu", "--lines", "10", "--prompt", "Select Emoji: "]
    elif finder == "tofi":
        cmd = ["tofi", "--prompt-text", "Select Emoji: "]
    elif finder == "rofi":
        cmd = ["rofi", "-dmenu", "-l", "10", "-p", "Select Emoji:"]
    else:  # dmenu (X11 fallback)
        cmd = ["dmenu", "-l", "10", "-p", "Select Emoji:"]

    try:
        result = subprocess.run(
            cmd,
            input=emoji_data,
            capture_output=True,
            text=True,
            encoding="utf-8",
            check=False,
        )

        if result.returncode == 0 and result.stdout.strip():
            selected = result.stdout.strip()
            emoji = selected.split()[0] if selected else ""
            return emoji

    except (IOError, subprocess.SubprocessError) as e:
        print(f"Error showing menu: {e}", file=sys.stderr)

    return None


def copy_to_clipboard(text):
    """Copy text to clipboard (wl-copy on Wayland, xsel/xclip on X11)"""
    try:
        if IS_WAYLAND:
            subprocess.run(
                ["wl-copy"], input=text, text=True, encoding="utf-8", check=True
            )
        else:
            xsel_ok = (
                subprocess.run(
                    ["which", "xsel"], capture_output=True, check=False
                ).returncode
                == 0
            )
            if xsel_ok:
                subprocess.run(
                    ["xsel", "--clipboard", "--input"],
                    input=text,
                    text=True,
                    encoding="utf-8",
                    check=True,
                )
            else:
                subprocess.run(
                    ["xclip", "-selection", "clipboard"],
                    input=text,
                    text=True,
                    encoding="utf-8",
                    check=True,
                )
        return True
    except subprocess.CalledProcessError as e:
        print(f"Error copying to clipboard: {e}", file=sys.stderr)
        return False


def main():
    """Main function"""
    parser = argparse.ArgumentParser(
        description="Emoji Picker (Wayland) - Download and select emojis"
    )
    parser.add_argument(
        "--update", action="store_true", help="Force update the emoji cache"
    )
    parser.add_argument(
        "--download-only",
        action="store_true",
        help="Only download emoji data, do not show menu",
    )

    args = parser.parse_args()

    if args.update or args.download_only:
        success = download_emoji_data()
        sys.exit(0 if success else 1)

    finder = check_dependencies()
    selected_emoji = show_selection_menu(finder)

    if selected_emoji:
        if copy_to_clipboard(selected_emoji):
            print(selected_emoji)
        else:
            sys.exit(1)
    else:
        sys.exit(1)


if __name__ == "__main__":
    main()
