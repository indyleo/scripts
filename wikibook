#!/bin/bash
# wikibook

# --- Display server detection ---
if [ -n "$WAYLAND_DISPLAY" ]; then
    MENU() { rofi -dmenu -i -p "$1"; }
else
    MENU() { dmenu -i -p "$1"; }
fi

WIKIS=(
    "Terraria Wiki:terrabook"
    "Calamity Wiki:calbook"
    "Infernum Wiki:inferbook"
    "Fargo's Wiki:fargobook"
)

selected=$(printf '%s\n' "${WIKIS[@]}" | cut -d':' -f1 | MENU "Select Wiki")

[ -z "$selected" ] && exit 0

for wiki in "${WIKIS[@]}"; do
    display_name="${wiki%%:*}"
    script_name="${wiki##*:}"
    if [ "$selected" = "$display_name" ]; then
        "$script_name"
        exit 0
    fi
done
