#!/bin/env bash

set -euo pipefail

# --- Display server detection ---
if [ -n "${WAYLAND_DISPLAY:-}" ]; then
    MENU() { rofi -dmenu -l 5 -p "$1"; }
    PROMPT() { rofi -dmenu -p "$1"; }
else
    MENU() { dmenu -l 5 -p "$1"; }
    PROMPT() { dmenu -p "$1"; }
fi

notes_dir="$HOME/Documents/Markdown/Notes"
today="$(date +%F_%T | tr ':' '-')"

function getfiles() {
    find "$notes_dir" -maxdepth 2 -type f \
        ! -path '*/.*' \
        -printf "%T@ ./%P\n" | sort -nr | cut -d' ' -f2-
}

if [[ ! -d "$notes_dir" ]]; then
    echo "$notes_dir is not a directory, making one"
    mkdir -p "$notes_dir"
fi

function fbopen() {
    local file="$1"

    if [[ -z "$TERMINAL" ]]; then
        echo "TERMINAL is not set"
        exit 1
    fi

    if [[ "$TERMINAL" == "wezterm" ]]; then
        wezterm start -- "$SHELL" -c "${EDITOR:-nvim} \"$file\""

    elif [[ "$TERMINAL" == "st" ]]; then
        st -e "$SHELL" -c "${EDITOR:-nvim} \"$file\""

    else
        $TERMINAL -e "$SHELL" -c "${EDITOR:-nvim} \"$file\""
    fi
}

function new_note() {
    name="$(echo "" | PROMPT "Enter a name (default: $today, fmt: Notes_\$name/\$today.md): " <&-)" || exit 0
    : "${name:=$today}"
    filedir="$(gennotes "$name")"
    "${GEDIT:-fbopen}" "$filedir"
}

function notebook() {
    choice=$(echo -e " New Note\n$(getfiles)" | MENU "Choose note or create new: ")
    case "$choice" in
        " New Note")
            new_note
            ;;
        *.md)
            "${GEDIT:-fbopen}" "$notes_dir/$choice"
            ;;
        *)
            exit 1
            ;;
    esac
}

notebook
