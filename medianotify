#!/usr/bin/env bash
# medianotify - Event-driven media player notification daemon
# Monitors media state changes via playerctl events and queries mediactl

set -euo pipefail

# ============================================================================
# CONFIGURATION
# ============================================================================

readonly SCRIPT_NAME="medianotify"
readonly STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/medianotify"
readonly STATE_FILE="$STATE_DIR/last_state"
readonly EVENT_PIPE="$STATE_DIR/event_pipe"
readonly NOTIFICATION_TIMEOUT=5000
readonly NOTIFICATION_APP="Media Player"

# Debounce settings (milliseconds)
readonly DEBOUNCE_TIME_MS=120
declare -g LAST_EVENT_TIME_MS=0

# Track notification history (store timestamps in seconds)
declare -gA NOTIFIED_TRACKS=()

# Job tracking
declare -ga MONITOR_PIDS=()

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================

function log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" >&2
}

function die() {
    log "ERROR: $*"
    exit 1
}

function check_dependencies() {
    command -v mediactl &>/dev/null || die "mediactl not found in PATH"
    command -v playerctl &>/dev/null || die "playerctl not found in PATH"
    command -v notify-send &>/dev/null || die "notify-send not found"
}

function init_state_dir() {
    mkdir -p "$STATE_DIR"
    if [[ ! -p "$EVENT_PIPE" ]]; then
        rm -f "$EVENT_PIPE"
        mkfifo "$EVENT_PIPE"
    fi
}

function get_current_time_ms() {
    date +%s%3N
}

function should_debounce() {
    local current_time_ms
    current_time_ms=$(get_current_time_ms)

    local elapsed=$((current_time_ms - LAST_EVENT_TIME_MS))

    if (( elapsed < DEBOUNCE_TIME_MS )); then
        return 0  # Should debounce
    fi

    LAST_EVENT_TIME_MS=$current_time_ms
    return 1  # Don't debounce
}

function dwmblocks_signal() {
    local signal="$1"
    if [[ -z "$signal" ]]; then
        echo "Usage: dwmblocks_signal SIGNAL" >&2
        exit 1
    fi
    if pgrep -x "dwmblocks" >/dev/null; then
        pkill -RTMIN+"$signal" dwmblocks
        echo "󰡕  Success: Sent signal $signal to dwmblocks"
    fi
    return 0
}

# ============================================================================
# STATE MANAGEMENT
# ============================================================================

function load_state() {
    if [[ -f "$STATE_FILE" ]]; then
        cat "$STATE_FILE"
    else
        echo $'\t\t\t\t\t'
    fi
}

function save_state() {
    echo "$1" > "$STATE_FILE"
}

function get_track_key() {
    echo "${1}::${2}"
}

# Cache the last known-good art_url per track (title::artist) on disk, since
# firefox-mpris intermittently omits mpris:artUrl from its metadata even
# while the same track keeps playing - if we've seen it once, reuse it.
# Uses files (not an associative array) so the background retry subshell
# in retry_notify_with_art can share updates with the main process.
function art_cache_path() {
    local key="$1" hash
    hash=$(echo -n "$key" | md5sum | cut -d' ' -f1)
    echo "$STATE_DIR/artcache_${hash}"
}

function art_cache_get() {
    local path
    path=$(art_cache_path "$1")
    [[ -f "$path" ]] && cat "$path"
    return 0
}

function art_cache_set() {
    local path
    path=$(art_cache_path "$1")
    echo "$2" > "$path" 2>/dev/null || true
}

function should_notify() {
    local old_state="$1"
    local new_state="$2"

    local old_status old_title old_artist
    local new_type new_status new_title new_artist

    IFS=$'\t' read -r _ _ old_status old_title old_artist _ <<< "$old_state"
    IFS=$'\t' read -r new_type _ new_status new_title new_artist _ <<< "$new_state"

    # ONLY notify when something is Playing
    [[ "$new_status" != "Playing" ]] && return 1

    local track_key
    track_key=$(get_track_key "$new_title" "$new_artist")

    local current_time_sec
    current_time_sec=$(date +%s)

    # Check history window (10 seconds)
    if [[ -n "${NOTIFIED_TRACKS[$track_key]:-}" ]]; then
        local last_notif_time="${NOTIFIED_TRACKS[$track_key]}"
        local time_diff=$((current_time_sec - last_notif_time))

        if [[ $time_diff -lt 10 ]]; then
            return 1
        fi
    fi

    # Update notification timestamp
    NOTIFIED_TRACKS[$track_key]=$current_time_sec
    return 0
}

# ============================================================================
# Fetching Artwork
# ===========================================================================

function fetch_art() {
    local art_url="$1"
    [[ -z "$art_url" ]] && return 1

    if [[ "$art_url" == file://* ]]; then
        local path="${art_url#file://}"
        [[ -f "$path" ]] || return 1

        # Some MPRIS bridges (e.g. firefox-mpris) treat this as a live,
        # frequently-rotated thumbnail file - it can be replaced or deleted
        # moments after we read the metadata, even if it existed when we
        # checked. Snapshot it into our own cache immediately so notify-send
        # has a stable file to load, decoupled from the source's rotation.
        local cache_key ext cache_path
        cache_key=$(echo "$path" | md5sum | cut -d' ' -f1)
        ext="${path##*.}"
        cache_path="$STATE_DIR/art_local_${cache_key}.${ext}"

        cp -f "$path" "$cache_path" 2>/dev/null || return 1
        echo "$cache_path"
        return 0
    fi

    if [[ "$art_url" == http://* || "$art_url" == https://* ]]; then
        # Use URL hash as cache key so we don't re-download the same art
        local cache_key
        cache_key=$(echo "$art_url" | md5sum | cut -d' ' -f1)
        local cache_path="$STATE_DIR/art_${cache_key}.jpg"

        if [[ ! -f "$cache_path" ]]; then
            curl -fsSL --max-time 5 -o "$cache_path" "$art_url" 2>/dev/null || {
                rm -f "$cache_path"
                return 1
            }
        fi

        echo "$cache_path"
        return 0
    fi

    return 1
}

# ============================================================================
# NOTIFICATION FORMATTING
# ============================================================================

function is_bogus_chromium_path() {
    # Chromium (and some other browsers) sometimes report their own internal
    # lock/IPC socket files (/tmp/.org.chromium.Chromium.XXXXXX) as MPRIS
    # album/art metadata when the page doesn't expose real Media Session info.
    # Treat those as junk.
    local val="$1"
    [[ "$val" =~ /tmp/\.org\.(chromium|mozilla|vivaldi) ]] && return 0
    return 1
}

function looks_like_art_path() {
    # Some MPRIS bridges (e.g. firefox-mpris) leak the actual artwork
    # location into xesam:album instead of populating mpris:artUrl at all.
    # Recognize a bare file:// URL or an absolute path ending in a common
    # image extension so we can recover it as art instead of showing it
    # as literal album text.
    local val="$1"
    [[ -z "$val" ]] && return 1
    [[ "$val" == file://* ]] && return 0
    [[ "$val" =~ ^/.*\.(png|jpe?g|gif|bmp|webp)$ ]] && return 0
    return 1
}

function send_notification() {
    local old_state="$1"
    local new_state="$2"
    local art_url="$3"

    local new_type new_status new_title new_artist new_album
    IFS=$'\t' read -r new_type _ new_status new_title new_artist new_album <<< "$new_state"

    local source_icon
    case "$new_type" in
        browser) source_icon="🌐" ;;
        song)    source_icon="🎵" ;;
        *)       source_icon="" ;;
    esac

    # Some browsers/MPRIS bridges leak the real artwork location into the
    # *album text* field (xesam:album) instead of (or in addition to)
    # artUrl - either as a Chromium internal temp-socket path, or (e.g.
    # firefox-mpris) as a plain file:// URL / image path. The file itself
    # is real, valid art though - so if album looks like one of those and
    # art_url is empty/unusable, use the album value as the art source.
    if [[ "$new_type" == "browser" ]] && { is_bogus_chromium_path "$new_album" || looks_like_art_path "$new_album"; }; then
        [[ -z "$art_url" ]] && art_url="$new_album"
        new_album=""
    fi

    # Some sites report a literal placeholder instead of leaving it blank.
    case "$new_album" in
        "Unknown"|"Unknown Album"|"[Unknown Album]") new_album="" ;;
    esac

    local notif_title="$source_icon Now Playing"
    local notif_body="$new_title"

    [[ -n "$new_artist" && "$new_artist" != "Unknown" ]] && \
        notif_body="$notif_body"$'\n'"by $new_artist"

    [[ -n "$new_album" && "$new_album" != "Unknown" ]] && \
        notif_body="$notif_body"$'\n'"from $new_album"

    local notify_cmd=(
        notify-send
        -t "$NOTIFICATION_TIMEOUT"
        -a "$NOTIFICATION_APP"
        -u normal
        -h string:x-canonical-private-synchronous:medianotify
    )

    # Resolve art to a local path (downloads if remote). We keep this even
    # for the Chromium temp-path case since that file is real artwork.
    local art_path
    if art_path=$(fetch_art "$art_url"); then
        log "DEBUG: art resolved -> '$art_path' (exists=$([[ -f "$art_path" ]] && echo yes || echo NO))"
        notify_cmd+=(-i "$art_path")
    else
        log "DEBUG: fetch_art failed for art_url='$art_url'"
    fi

    notify_cmd+=("$notif_title" "$notif_body")

    local notify_err
    if ! notify_err=$("${notify_cmd[@]}" 2>&1); then
        log "Failed to send notification: $notify_err"
    fi
    log "Notification sent: $new_title"
}

# ============================================================================
# EVENT HANDLING
# ============================================================================

function retry_notify_with_art() {
    local target_key="$1"
    local prev_state="$2"
    local tries=0

    while [[ $tries -lt 24 ]]; do
        sleep 0.5
        local cur
        cur=$(mediactl status 2>/dev/null) || return
        [[ -z "$cur" ]] && return

        local type player status title artist album art_url
        IFS=$'\t' read -r type player status title artist album art_url <<< "$cur"
        local cur_key="$type"$'\t'"$player"$'\t'"$status"$'\t'"$title"$'\t'"$artist"$'\t'"$album"

        # Bail if the track changed underneath us - don't show late art
        # for a track that's no longer playing.
        [[ "$cur_key" != "$target_key" ]] && { log "DEBUG: retry_notify_with_art bailing, track changed"; return; }

        if [[ -n "$art_url" ]]; then
            log "DEBUG: art_url appeared on retry $((tries+1)), re-sending notification"
            art_cache_set "$(get_track_key "$title" "$artist")" "$art_url"
            send_notification "$prev_state" "$cur_key" "$art_url"
            return
        fi
        tries=$((tries+1))
    done
    log "DEBUG: gave up waiting for art_url after $tries retries"
}

function capture_art_from_line() {
    # Runs on every raw metadata-watcher line, unconditionally (no
    # debounce). firefox-mpris only includes mpris:artUrl in ONE of
    # several rapid-fire metadata dumps per track load - re-querying
    # afterward (via mediactl) almost always lands on a dump that lacks
    # it. Reading it straight out of the event line that has it is the
    # only reliable way to catch it.
    local line="$1"
    local p title artist album art_url
    IFS=$'\t' read -r p title artist album art_url <<< "$line"

    # Also recover art leaked into the album field (Chromium/firefox-mpris quirk)
    if [[ -z "$art_url" ]] && { is_bogus_chromium_path "$album" || looks_like_art_path "$album"; }; then
        art_url="$album"
    fi

    if [[ -n "$art_url" && -n "$title" ]]; then
        log "DEBUG: captured art_url directly from event stream for '$title'"
        art_cache_set "$(get_track_key "$title" "$artist")" "$art_url"
    fi
    return 0
}

function handle_event() {
    # Note: This function now runs in the MAIN process scope

    if should_debounce; then
        return
    fi

    # Get current state from mediactl
    local current_state
    current_state=$(mediactl status 2>/dev/null || echo $'idle\t\tIdle\t\t\t')

    local type player status title artist album art_url
    IFS=$'\t' read -r type player status title artist album art_url <<< "$current_state"

    if [[ -z "$type" ]]; then
        return
    fi

    local state_key="$type"$'\t'"$player"$'\t'"$status"$'\t'"$title"$'\t'"$artist"$'\t'"$album"
    local last_state
    last_state=$(load_state)

    if [[ "$state_key" != "$last_state" ]]; then
        dwmblocks_signal 23
    fi

    local cache_key
    cache_key=$(get_track_key "$title" "$artist")

    if [[ -n "$art_url" ]]; then
        art_cache_set "$cache_key" "$art_url"
    else
        local cached_art
        cached_art=$(art_cache_get "$cache_key")
        if [[ -n "$cached_art" ]]; then
            log "DEBUG: art_url empty, using cached art for '$title'"
            art_url="$cached_art"
        fi
    fi

    if should_notify "$last_state" "$state_key"; then
        send_notification "$last_state" "$state_key" "$art_url"
        if [[ -z "$art_url" ]]; then
            retry_notify_with_art "$state_key" "$last_state" &
            disown
        fi
    fi

    save_state "$state_key"
}

# ============================================================================
# MONITORING LOGIC
# ============================================================================

function kill_writers() {
    # Only kill the background 'playerctl' processes feeding the pipe
    for pid in "${MONITOR_PIDS[@]}"; do
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
        fi
    done
    MONITOR_PIDS=()
}

function spawn_writers() {
    kill_writers
    local current_players="$1"

    if [[ -n "$current_players" ]]; then
        log "Monitoring: $(echo "$current_players" | tr '\n' ' ')"

        # We redirect output to the Named Pipe
        # We assume the Main Loop is already reading from it
        playerctl -a -F metadata --format $'{{playerName}}\t{{title}}\t{{artist}}\t{{album}}\t{{mpris:artUrl}}' > "$EVENT_PIPE" 2>/dev/null &
        MONITOR_PIDS+=($!)

        playerctl -a -F status > "$EVENT_PIPE" 2>/dev/null &
        MONITOR_PIDS+=($!)
    fi
}

function main_loop() {
    log "Starting daemon..."

    # Ensure FIFO exists
    init_state_dir

    # 1. Open the FIFO for Read+Write (FD 3).
    # This prevents the 'read' loop from receiving EOF when writer processes die/restart.
    exec 3<> "$EVENT_PIPE"

    # 2. Start the background check for player list changes
    (
        local known_players=""
        while true; do
            local current_players
            current_players=$(playerctl -l 2>/dev/null || echo "")

            if [[ "$current_players" != "$known_players" ]]; then
                # Write a special internal signal to the pipe to trigger update
                echo "INTERNAL_UPDATE_PLAYERS $current_players" > "$EVENT_PIPE"
                known_players="$current_players"
            fi
            sleep 2
        done
    ) &
    local CHECKER_PID=$!

    # 3. Main Blocking Loop: Reads from FIFO
    # Because we read from FD 3 or the file, and we keep it open, this loop never dies.
    while read -r line <&3; do
        if [[ "$line" == "INTERNAL_UPDATE_PLAYERS "* ]]; then
            # Player list changed
            local new_list="${line#INTERNAL_UPDATE_PLAYERS }"
            spawn_writers "$new_list"
            # Trigger an immediate check
            handle_event
        else
            capture_art_from_line "$line"
            handle_event
        fi
    done

    # If we get here, something broke the pipe mechanism
    kill "$CHECKER_PID" 2>/dev/null
}

# ============================================================================
# SIGNAL HANDLING
# ============================================================================

function cleanup() {
    log "Shutting down..."
    kill_writers
    pkill -P $$ 2>/dev/null || true
    rm -f "$EVENT_PIPE" "$STATE_DIR/events" 2>/dev/null
    rm -f "$STATE_DIR"/art_*.jpg "$STATE_DIR"/art_local_*.* "$STATE_DIR"/artcache_* 2>/dev/null
    exec 3>&- # Close FD
    exit 0
}

trap cleanup SIGINT SIGTERM EXIT

# ============================================================================
# ENTRY POINT
# ============================================================================

check_dependencies
main_loop
